require "shellwords"

default_platform(:android)

def release_version_from_tag!
  tag_name = ENV["GITHUB_REF_NAME"]

  if tag_name.to_s.empty?
    tag_name = Actions.sh("git tag --points-at HEAD", log: false).split("\n").find do |tag|
      tag.match?(/^v\d+\.\d+\.\d+$/)
    end
  end

  match = tag_name.to_s.match(/^v(\d+\.\d+\.\d+)$/)
  return match[1] if match

  UI.user_error!("Missing release tag. Expected a tag like v1.2.3 on the current commit.")
end

platform :android do
  desc "Submit a new build to Play Store closed test track"
  lane :beta do
    version_name = release_version_from_tag!
    version_codes = google_play_track_version_codes(
      package_name: "com.tryzeon.app",
      track: "alpha",
      json_key_data: ENV["PLAYSTORE_SERVICE_ACCOUNT_JSON"]
    )
    
    version_code = (version_codes.max || 0) + 1

    UI.message("---------------------------------------------------------")
    UI.message("🚀 Building Version: #{version_name}+#{version_code}")
    UI.message("---------------------------------------------------------")

    Dir.chdir("../") do
      sh("flutter build appbundle --release --build-name=#{version_name.shellescape} --build-number=#{version_code}")
    end

    upload_to_play_store(
      track: 'alpha',
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["PLAYSTORE_SERVICE_ACCOUNT_JSON"]
    )
  end

  desc "Deploy a new version to the Google Play"
  lane :deploy do
    version_name = release_version_from_tag!
    version_codes = google_play_track_version_codes(
      package_name: "com.tryzeon.app",
      track: "production",
      json_key_data: ENV["PLAYSTORE_SERVICE_ACCOUNT_JSON"]
    )
    
    version_code = (version_codes.max || 0) + 1

    UI.message("---------------------------------------------------------")
    UI.message("🚀 Building Version: #{version_name}+#{version_code}")
    UI.message("---------------------------------------------------------")

    Dir.chdir("../") do
      sh("flutter build appbundle --release --build-name=#{version_name.shellescape} --build-number=#{version_code}")
    end

    upload_to_play_store(
      track: 'production',
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["PLAYSTORE_SERVICE_ACCOUNT_JSON"]
    )
  end
end

# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

def release_version_from_tag!
  tag_name = ENV["GITHUB_REF_NAME"]

  if tag_name.to_s.empty?
    tag_name = Actions.sh("git tag --points-at HEAD", log: false).split("\n").find do |tag|
      tag.match?(/^v\d+\.\d+\.\d+$/)
    end
  end

  match = tag_name.to_s.match(/^v(\d+\.\d+\.\d+)$/)
  return match[1] if match

  UI.user_error!("Missing release tag. Expected a tag like v1.2.3 on the current commit.")
end

def beta_version_number!
  version_number = ENV["RELEASE_VERSION"].to_s.strip
  return version_number if version_number.match?(/^\d+\.\d+\.\d+$/)

  UI.user_error!("Missing RELEASE_VERSION. Expected a semantic version like 1.2.3 for beta builds.")
end

def latest_testflight_build_number!(api_key, version_number)
  latest_build_number = app_store_build_number(
    api_key: api_key,
    live: false,
    version: version_number
  )

  return latest_build_number.to_s if latest_build_number.to_i > 0

  UI.user_error!("No TestFlight build found for version #{version_number}. Upload a beta build before promoting a release.")
end

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_API_KEY_ISSUER_ID'],
      key_content: ENV['APP_STORE_CONNECT_API_KEY_KEY_CONTENT'],
    )

    setup_ci

    sync_code_signing(type: "appstore")

    version_number = beta_version_number!
    build_number = app_store_build_number(
      api_key: api_key,
      live: false,
    ) + 1

    UI.message("---------------------------------------------------------")
    UI.message("🚀 Building Version: #{version_number}+#{build_number}")
    UI.message("---------------------------------------------------------")

    build_app(
      export_method: "app-store",
      xcargs: "FLUTTER_BUILD_NAME=#{version_number} FLUTTER_BUILD_NUMBER=#{build_number}"
    )
    
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build and upload a tagged release to App Store"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_API_KEY_ISSUER_ID'],
      key_content: ENV['APP_STORE_CONNECT_API_KEY_KEY_CONTENT'],
    )

    version_number = release_version_from_tag!
    build_number = latest_testflight_build_number!(api_key, version_number)

    UI.message("---------------------------------------------------------")
    UI.message("🚀 Releasing existing TestFlight build: #{version_number}+#{build_number}")
    UI.message("---------------------------------------------------------")

    upload_to_app_store(
      api_key: api_key,
      app_version: version_number,
      build_number: build_number,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      run_precheck_before_submit: false
    )
  end
end
